{
  "name": "play-sheet-music",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "services/omr-api",
    "packages/contracts"
  ],
  "scripts": {
    "dev": "concurrently -n web,omr -c blue,green \"npm run dev:web\" \"npm run dev:omr\"",
    "dev:web": "npm --workspace @play-sheet-music/web run dev",
    "dev:omr": "npm --workspace @play-sheet-music/omr-api run dev",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm --workspace @play-sheet-music/web run test:e2e",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
